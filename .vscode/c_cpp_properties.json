{
  "version": 4,
  "configurations": [
    {
      "name": "WSL",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/include",
        "/usr/include/efi",
        "/usr/include/efi/x86_64",
        "/usr/lib/gcc/**"
      ],
      "defines": [
        "__GNUC__",
        "__x86_64__",
        "GNU_EFI_USE_MS_ABI"
      ],
      "compilerPath": "/usr/bin/gcc",
      "compilerArgs": [
        "-fshort-wchar",
        "-ffreestanding",
        "-mno-red-zone"
      ],
      "cStandard": "c11",
      "intelliSenseMode": "linux-gcc-x64"
    }
  ]
}
